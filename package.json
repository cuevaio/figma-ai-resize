{
  "name": "hello-world-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.2.22",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "watch": "turbo run watch --filter=@hello-world/figma-plugin",
    "lint": "turbo run lint",
    "build:plugin": "turbo run build --filter=@hello-world/figma-plugin",
    "build:web": "turbo run build --filter=@hello-world/web",
    "dev:web": "turbo run dev --filter=@hello-world/web",
    "lint:web": "turbo run lint --filter=@hello-world/web"
  },
  "devDependencies": {
    "turbo": "^2.5.6"
  }
}
